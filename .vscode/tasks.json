{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Workbench: Start",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\workbench-web\\launcher.ps1",
                "-Mode",
                "serve",
                "-Port",
                "7540",
                "-RestartOnPortInUse",
                "-NoPortDrift",
                "-Detached"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": false,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "workbench-web",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "Workbench: Restart",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\workbench-web\\launcher.ps1",
                "-Mode",
                "serve",
                "-Port",
                "7540",
                "-RestartOnPortInUse",
                "-NoPortDrift",
                "-Restart",
                "-Detached"
            ],
            "isBackground": false,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "workbench-web",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Workbench: Stop",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\workbench-web\\launcher.ps1",
                "-Mode",
                "stop",
                "-Port",
                "7540"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "group": "workbench-web",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Workbench: Debug: Stop",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\workbench-web\\launcher.ps1",
                "-Mode",
                "stop",
                "-Port",
                "7540"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "group": "workbench-web",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Workbench: Debug: Ensure Port 7540 Free",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "try { & '${workspaceFolder}\\tools\\workbench-web\\launcher.ps1' -Mode stop -Port 7540 | Out-Null } catch { } ; Start-Sleep -Milliseconds 200 ; try { $l = [System.Net.Sockets.TcpListener]::new([System.Net.IPAddress]::Loopback, 7540) ; $l.Start() ; $l.Stop() ; Write-Host 'Port 7540 is free.' ; exit 0 } catch { Write-Host 'ERROR: Port 7540 is in use. Close the other process (or change the debug port in .vscode/launch.json) then try again.' ; exit 1 }"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "workbench-web",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}